# LinkedIn
LINKEDIN_EMAIL=your.email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# Naukri
NAUKRI_EMAIL=your.email@gmail.com
NAUKRI_PASSWORD=your_naukri_password

# Gmail (use App Password, NOT regular password)
# Enable 2FA: https://support.google.com/accounts/answer/185833
GMAIL_USER=sender@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL=receiver@gmail.com

# Twilio WhatsApp
# Sign up: https://www.twilio.com/try-twilio
# Sandbox: send "join <keyword>" to +1-415-523-8886 on WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+919XXXXXXXXX
