# LinkedIn
LINKEDIN_EMAIL=your.email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# Naukri
NAUKRI_EMAIL=your.email@gmail.com
NAUKRI_PASSWORD=your_naukri_password

# Email alerts (generic SMTP: Brevo/Outlook/Gmail/custom)
# Brevo example:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USE_SSL=false
# SMTP_USER=your_brevo_login
# SMTP_PASSWORD=your_brevo_smtp_key
# SMTP_FROM=alerts@yourdomain.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=alerts@example.com
ALERT_EMAIL=receiver@gmail.com

# Backward compatibility (legacy Gmail keys, optional)
# GMAIL_USER=sender@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Twilio WhatsApp
# Sign up: https://www.twilio.com/try-twilio
# Sandbox: send "join <keyword>" to +1-415-523-8886 on WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+919XXXXXXXXX